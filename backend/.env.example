# Copy to backend/.env and fill in. Never commit .env.

# Server
PORT=8080
FLASK_DEBUG=1

# When 1, /v1/parse-menu returns a fixed ParsedMenu without Vision/Gemini (local dev).
MOCK_MENU_PARSE=1

# Supabase (same project as the Expo app)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role — server only; used to download from Storage by path (RLS bypass).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: verify Bearer JWT from the app (same JWT secret as Supabase)
# SUPABASE_JWT_SECRET=

# Google Cloud — Vision OCR + Vertex Gemini (required when MOCK_MENU_PARSE=0)
# Enable "Cloud Vision API" and "Vertex AI API" on the same GCP project as the service account.
# Grant the service account at least: roles/aiplatform.user (Vertex AI User).
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GCP_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.0-flash-001
# MENU_LLM_STRATEGY=text_first
#   text_first — OCR text only first; retry with image+text if invalid or empty dishes (default)
#   multimodal_always — one call with OCR text + image (best layout fidelity, higher cost)
#   text_only — text only, no image (cheapest; no retry)
#   image_only — skip OCR; one call with image only (faster; layout signal, may be less precise)

# US11: minimum seconds between AI calorie estimates for the same user (or IP) and dish (0 = off).
# CALORIE_ESTIMATE_MIN_INTERVAL_SECONDS=30

# When the API sits behind reverse proxies, set to the number of trusted hops in X-Forwarded-For (see Werkzeug ProxyFix). 0 = disabled (local dev).
# TRUSTED_PROXY_HOPS=1

# Dish image generation (US3)
# Generate preview images server-side and upload to Supabase Storage.
# Requires Vertex AI image generation in the same GCP project.
# VERTEX_IMAGE_MODEL=imagen-3.0-fast-generate-001
# DISH_IMAGES_BUCKET=dish-images
